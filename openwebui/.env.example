# Copy this file to .env and fill in real values before running docker compose.

# Keep this value stable after the first run. Generate a long random value.
WEBUI_SECRET_KEY=replace-with-a-long-random-secret

# Set true only for the first admin account creation, then change to false and restart.
ENABLE_SIGNUP=true

# OpenAI-compatible provider settings. The base URL must include /v1.
# Examples:
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# SiliconFlow: https://api.siliconflow.cn/v1
WEBUI_URL=http://127.0.0.1:3000
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_BASE_URLS=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-your-admin-api-key
OPENAI_API_KEYS=replace-with-your-admin-api-key

# Optional. Leave empty to choose models in Open WebUI admin settings.
DEFAULT_MODELS=

WEBUI_NAME=小羊 AI 对话小屋

# Use an external OpenAI-compatible embedding endpoint to avoid downloading a local HuggingFace model.
RAG_EMBEDDING_ENGINE=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_OPENAI_API_BASE_URL=https://api.openai.com/v1
RAG_OPENAI_API_KEY=replace-with-your-admin-api-key
RAG_EMBEDDING_MODEL_AUTO_UPDATE=false
HF_HUB_OFFLINE=1
